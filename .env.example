# PostHog Analytics (EU Cloud)
# Get your key from: https://eu.posthog.com/project/settings
VITE_POSTHOG_KEY=phc_your_project_api_key_here
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# MitLivMed backend API base URL.
# Local dev: http://localhost:3001 (run the API locally in Stripe TEST mode, and
# set the API's own LANDING_URL=http://localhost:8080 so CORS + the donation
# return_url point back at this Vite dev server). Production: https://api.mitlivmed.dk
VITE_API_BASE_URL=http://localhost:3001

# Stripe publishable key — safe to expose in the browser (it is NOT a secret).
# Must match the API's Stripe mode: pk_test_… with the test backend, pk_live_… in prod.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
